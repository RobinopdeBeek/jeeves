# Copy to .env and fill in values. All variables are optional unless noted.

# HTTP port (default: 3000)
JEEVES_PORT=3000

# SQLite database file (default: ./data/jeeves.db)
JEEVES_DB_PATH=./data/jeeves.db

# Target repository for the default project (default: repo root)
JEEVES_REPO_PATH=.

# Required for Sandcastle Docker runs (cursor agent auth)
CURSOR_API_KEY=
