# Copy to .env and fill in values. All variables are optional unless noted.

# API/server HTTP port (default: 3939)
JEEVES_PORT=3939

# Vite dev client port (default: 3940)
JEEVES_CLIENT_PORT=3940

# Target repository for the default project (default: Jeeves repo root).
# Project store is created at <repo>/.jeeves/ on first use (gitignored).
# For dogfooding, point at the Pantry Checker fixture sibling repo:
# JEEVES_REPO_PATH=../jeeves-test-pantry-checker
JEEVES_REPO_PATH=.

# Override paths for the active project store (defaults derived from JEEVES_REPO_PATH):
# JEEVES_DB_PATH=<repo>/.jeeves/jeeves.db
# JEEVES_WORKTREE_ROOT=<repo>/.jeeves/worktrees

# Required for @cursor/sdk local agent runs and Cursor CLI (ACP chat)
CURSOR_API_KEY=
