{
  "name": "jeeves",
  "version": "1.0.0",
  "description": "A personal workflow board that runs a Matt Pocock-inspired development pipeline visually.",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:guard && npm run dev:ports && concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:guard": "tsx scripts/dev-guard.ts",
    "dev:ports": "tsx scripts/ensure-ports.ts",
    "dev:client": "vite",
    "dev:server": "nodemon --watch server --ext ts --exec \"tsx server/index.ts\"",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "spike:sdk": "tsx .scratch/spike-sdk-worktree.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@cursor/sdk": "^1.0.18",
    "@hono/node-server": "^2.0.8",
    "@tabler/icons-react": "^3.44.0",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "nanoid": "^5.1.16",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "nodemon": "^3.1.14",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
